# =============================================================================
# Flo — Personal Finance App — Environment Variables
# Copy this file to .env.local and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Neon.tech)
# -----------------------------------------------------------------------------
# 1. Go to https://neon.tech → Create a new project
# 2. Copy the connection string from the dashboard
# 3. Use the pooled connection string for the app (port 5432 via pgBouncer)
#    Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# -----------------------------------------------------------------------------
# Auth.js (next-auth v5)
# -----------------------------------------------------------------------------
# AUTH_SECRET: run `npx auth secret` to generate a secure random value
AUTH_SECRET=your-auth-secret-here

# AUTH_URL: your app's base URL
# Development: http://localhost:3000
# Production: https://your-app.vercel.app
AUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Authorized redirect URIs — add BOTH of these:
#    - Development: http://localhost:3000/api/auth/callback/google
#    - Production:  https://your-app.vercel.app/api/auth/callback/google
# 4. Copy the Client ID and Client Secret below
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# =============================================================================
# Deployment — Vercel
# =============================================================================
# 1. Push this repo to GitHub
# 2. Import project in https://vercel.com/new
# 3. Add all env vars above in the Vercel dashboard (Settings → Environment Variables)
#    Use the Vercel secret names matching vercel.json:
#    @database_url, @auth_secret, @auth_url, @auth_google_id, @auth_google_secret
# 4. Run migrations against the production DB (Neon):
#    DATABASE_URL=<prod-url> npx prisma migrate deploy
# 5. Vercel will run `prisma generate && next build` automatically (see vercel.json)
# =============================================================================
